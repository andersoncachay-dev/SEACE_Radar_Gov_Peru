APP_NAME=SEACE Radar Gov Peru API
ENVIRONMENT=local
BACKEND_API_URL=http://127.0.0.1:8000
DATABASE_URL=sqlite:///./data/seace_radar.db
SECRET_KEY=change-this-secret-before-production
ACCESS_TOKEN_MINUTES=720
AUTO_CREATE_TABLES=false

# Menores a 8 UIT esta deshabilitado hasta estabilizar el scraper.
ENABLE_MENOR8_MODULE=false

# Scheduler automatico de perfiles activos.
ENABLE_SCHEDULER=true
SCHEDULER_INTERVAL_MINUTES=60
AUTO_SEND_ALERTS=true
ALERT_SENDER_INTERVAL_MINUTES=10

# Seed inicial.
ADMIN_EMAIL=admin@seace-radar.local
ADMIN_PASSWORD=Admin12345
ADMIN_FULL_NAME=Administrador SEACE Radar

# Alertas email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Alertas WhatsApp.
WHATSAPP_PROVIDER=
WHATSAPP_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_FROM=
